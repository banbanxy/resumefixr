# 环境变量配置
# 复制此文件为 .env.local 并填入真实值

# 问问 API
WENWEN_API_KEY=你的问问API密钥
WENWEN_BASE_URL=https://breakout.wenwen-ai.com
WENWEN_MODEL=claude-sonnet-4-6

# PayPal 收款邮箱（个人账户邮箱）
NEXT_PUBLIC_PAYPAL_EMAIL=你的PayPal邮箱

# Resend 邮件
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@your-domain.com

# 网站地址（部署后填入真实域名）
NEXT_PUBLIC_SITE_URL=https://your-domain.com
